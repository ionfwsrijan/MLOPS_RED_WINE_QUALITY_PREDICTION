# Environment: development | staging | production
ENV_TAG=development

# Data Ingestion
ENV_DATA_INGESTION_SOURCE_URL=https://github.com/entbappy/Branching-tutorial/raw/master/winequality-data.zip
ENV_DATA_INGESTION_ROOT_DIR=artifacts/data_ingestion
ENV_DATA_INGESTION_LOCAL_DATA_FILE=artifacts/data_ingestion/data.zip
ENV_DATA_INGESTION_UNZIP_DIR=artifacts/data_ingestion

# Data Validation
ENV_DATA_VALIDATION_ROOT_DIR=artifacts/data_validation
ENV_DATA_VALIDATION_DATA_FILE=artifacts/data_ingestion/winequality-red.csv
ENV_DATA_VALIDATION_STATUS_FILE=artifacts/data_validation/status.txt
ENV_DATA_VALIDATION_DRIFT_THRESHOLD=0.05

# Data Transformation
ENV_DATA_TRANSFORMATION_ROOT_DIR=artifacts/data_transformation
ENV_DATA_TRANSFORMATION_DATA_PATH=artifacts/data_ingestion/winequality-red.csv

# Model Trainer
ENV_MODEL_TRAINER_ROOT_DIR=artifacts/model_trainer
ENV_MODEL_TRAINER_TRAIN_DATA_PATH=artifacts/data_transformation/train.csv
ENV_MODEL_TRAINER_TEST_DATA_PATH=artifacts/data_transformation/test.csv
ENV_MODEL_TRAINER_MODEL_NAME=model.joblib

# Model Evaluation
ENV_MODEL_EVALUATION_ROOT_DIR=artifacts/model_evaluation
ENV_MODEL_EVALUATION_TEST_DATA_PATH=artifacts/data_transformation/test.csv
ENV_MODEL_EVALUATION_MODEL_PATH=artifacts/model_trainer/model.joblib
ENV_MODEL_EVALUATION_METRIC_FILE_NAME=artifacts/model_evaluation/metrics.json

# Model Registry
ENV_MODEL_REGISTRY_PATH=artifacts/model_registry.json
ENV_MODEL_REGISTRY_PRODUCTION_ALIAS=production
ENV_MODEL_REGISTRY_STAGING_ALIAS=staging
ENV_MODEL_REGISTRY_MAX_VERSIONS_TO_KEEP=10
ENV_MODEL_REGISTRY_QUALITY_GATE_MAX_RMSE_DEGRADATION_PCT=5.0

# Flask Server
ENV_FLASK_PORT=8080
ENV_FLASK_DEBUG=true

# Artifacts Root
ENV_ARTIFACTS_ROOT=artifacts

# Scalers
ENV_USE_SCALER=true
ENV_SCALER_TYPE=standard
